<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="gui.ProgramChooserController"
      spacing="10" alignment="CENTER">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Select a Program to Execute" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <ListView fx:id="programListView" VBox.vgrow="ALWAYS" prefHeight="400"/>

    <Button fx:id="selectButton" text="Select and Run" onAction="#handleSelectButton"
            style="-fx-font-size: 14px;" prefWidth="150"/>
</VBox>