<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.MainWindowController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #f0f0f0;">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10" />
            </padding>
            <Label text="Number of PrgStates:" />
            <TextField fx:id="nrPrgStatesTextField" editable="false" prefWidth="50" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="runOneStepButton" onAction="#handleRunOneStep" style="-fx-font-size: 14px; -fx-background-color: #4CAF50; -fx-text-fill: white;" text="Run One Step" />
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.7">
            <!-- Left side -->
            <VBox spacing="5">
                <padding>
                    <Insets bottom="5" left="5" right="5" top="5" />
                </padding>

                <!-- Heap Table -->
                <Label style="-fx-font-weight: bold;" text="Heap Table" />
                <TableView fx:id="heapTableView" prefHeight="150" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="heapAddressColumn" prefWidth="100" text="Address" />
                        <TableColumn fx:id="heapValueColumn" prefWidth="200" text="Value" />
                    </columns>
                </TableView>
            <Label prefHeight="17.0" prefWidth="105.0" text="SemaphoreTable" />
            <TableView fx:id="semaphoreTableView" prefHeight="200.0" prefWidth="200.0">
              <columns>
                <TableColumn fx:id="semaphoreIndexColumn" prefWidth="147.0" text="Index" />
                <TableColumn fx:id="semaphoreValueColumn" prefWidth="140.0" text="Value" />
                  <TableColumn fx:id="semaphoreListColumn" prefWidth="140.0" text="List of values" />
              </columns>
            </TableView>

                <!-- Out -->
                <Label style="-fx-font-weight: bold;" text="Output" />
                <ListView fx:id="outListView" prefHeight="100" VBox.vgrow="ALWAYS" />

                <!-- FileTable -->
                <Label style="-fx-font-weight: bold;" text="File Table" />
                <ListView fx:id="fileTableListView" prefHeight="80" VBox.vgrow="ALWAYS" />
            </VBox>

            <!-- Right side -->
            <VBox spacing="5">
                <padding>
                    <Insets bottom="5" left="5" right="5" top="5" />
                </padding>

                <!-- PrgState IDs -->
                <Label style="-fx-font-weight: bold;" text="PrgState IDs" />
                <ListView fx:id="prgStateIdListView" prefHeight="80" />

                <!-- SymTable -->
                <Label style="-fx-font-weight: bold;" text="Symbol Table" />
                <TableView fx:id="symTableView" prefHeight="150" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="symTableVarNameColumn" prefWidth="150" text="Variable Name" />
                        <TableColumn fx:id="symTableValueColumn" prefWidth="150" text="Value" />
                    </columns>
                </TableView>

                <!-- ExeStack -->
                <Label style="-fx-font-weight: bold;" text="Execution Stack" />
                <ListView fx:id="exeStackListView" prefHeight="200" VBox.vgrow="ALWAYS" />
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
